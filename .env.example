DATABASE_URL=postgres://callforge:callforge@localhost:5434/callforge
CLAUDE_CLI_PATH=/usr/local/bin/claude
CODEX_CLI_PATH=/usr/local/bin/codex
GEMINI_CLI_PATH=/usr/local/bin/gemini
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GITHUB_TOKEN=
NETLIFY_SITE_ID=
WEATHER_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
BUSINESS_PHONE=
DISCORD_WEBHOOK_URL=

# Agent behavior
CITY_SOURCE_MODE=deployment_candidates
AGENT7_PROVIDER=database
AGENT1_RESEARCH_ENABLED=true
AGENT2_RESEARCH_ENABLED=true
AGENT3_CITY_CONCURRENCY=2
AGENT3_ENFORCE_NEW_CITY_CAP=false
AGENT3_MAX_NEW_CITIES_PER_WEEK=3

# Indexation controls
SEARCH_CONSOLE_INTEGRATION_ENABLED=false
INDEXATION_KILL_SWITCH_ENABLED=false
INDEXATION_MIN_PAGE_AGE_DAYS=21
INDEXATION_LOOKBACK_DAYS=30
INDEXATION_RATIO_THRESHOLD=0.5

NODE_ENV=development
